  "devDependencies": {
    "@types/node": "20.17.6",
    "@types/pg": "8.11.10",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.1",
    "@playwright/test": "1.49.0",
    "drizzle-kit": "0.28.1",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
